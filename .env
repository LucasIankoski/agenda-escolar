# App
APP_NAME=agenda-api
SERVER_PORT=8080

# Database
DB_URL=jdbc:postgresql://localhost:5436/diary
DB_USERNAME=admin
DB_PASSWORD=agenda

# JPA / Hibernate
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=true

# Flyway
FLYWAY_ENABLED=true
FLYWAY_LOCATIONS=classpath:db/migration
FLYWAY_BASELINE_ON_MIGRATE=true

# JWT
JWT_SECRET=uma-chave-bem-grande-com-mais-de-32-chars-123456
JWT_EXPIRATION=86400000
